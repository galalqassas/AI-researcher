OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud
# OLLAMA_MODEL_LIGHT: Lighter model for per-paper summaries. When set to the same
# model as OLLAMA_MODEL, tiered routing is effectively a no-op. Change to a
# smaller model (e.g. gemma3:4b) for cost savings once pulled via `ollama pull`.
OLLAMA_MODEL_LIGHT=gemma4:31b-cloud
OLLAMA_MAX_TOKENS_PER_RUN=0
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
ARXIV_FROM_DATE=2020-01-01
ARXIV_MAX_RESULTS=2
SIMILARITY_THRESHOLD=0.35
RRF_K=60
DEDUP_THRESHOLD=0.85
APP_HOST=127.0.0.1
APP_PORT=8000

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=papers
QDRANT_EMBED_DIMENSION=768